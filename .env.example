# =============================================================================
# Invent-MAG Frontend (invent-mag-fe) — Environment Variables
# Copy this file to .env and fill in the values for local development.
# In production (Vercel), set these in the Vercel dashboard under
# Project Settings → Environment Variables.
# =============================================================================

# Backend API URL (the central Laravel backend)
# Production: https://api.invent-mag.web.id
# Local:      http://127.0.0.1.nip.io (or your local backend URL)
PUBLIC_BACKEND_URL=https://api.invent-mag.web.id

# Demo links shown on the landing page, navigation, and pricing sections
PUBLIC_DEMO_STARTER_URL=https://demo-starter.invent-mag.web.id/admin/login
PUBLIC_DEMO_PRO_URL=https://demo-pro.invent-mag.web.id/admin/login
